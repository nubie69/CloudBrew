{
  "expo": {
    "name": "Coffee Management System",
    "slug": "coffee-management-system",
    "scheme": "cloudbrew",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Cloud Brew to access your photos so admins can upload coffee images."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {}
  }
}
